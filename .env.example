# LLM
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.2
MAX_AGENT_ITERATIONS=10

# Database
DATABASE_URL=postgresql://agent_user:agent_pass@localhost:5432/agent_db

# Rate Limiting
RATE_LIMIT=30/minute

# Retry Logic
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Tools Config
SEARCH_API_KEY=optional-serpapi-key
WEATHER_API_KEY=optional-openweathermap-key
